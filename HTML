<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estación Arbeláez - Multi-Gráfica</title>
    
    <!-- Librerías de Visualización e Iconos es solo para introcir icono vectoriales nos es tan necesario-->
    <!-- La pajo es para manejar los datos recividos de manera inalambrica por MQTT-->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/paho-mqtt/1.0.1/mqttws31.min.js"></script>
    
    <style>
        :root { 
            --primary: #f97316;    /* Naranja para Temperatura */
            --secondary: #3b82f6;  /* Azul para Humedad */
            --bg: #f8fafc; 
            --dark: #1e293b; 
            --white: #ffffff; 
        }

        body { 
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; 
            margin: 0; 
            background: var(--bg); 
            color: var(--dark); 
            display: flex; 
            height: 100vh; 
            overflow: hidden; 
        }

        .app-container { display: flex; width: 100%; }

        /* Barra Lateral */
        .sidebar { 
            width: 260px; 
            background: var(--dark); 
            color: white; 
            padding: 25px; 
            display: flex; 
            flex-direction: column; 
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
        }

        .sidebar-header { display: flex; align-items: center; gap: 12px; margin-bottom: 40px; }
        .sidebar-header i { font-size: 28px; color: var(--primary); }

        .sidebar-nav { display: flex; flex-direction: column; gap: 10px; }

        .nav-item {
            padding: 12px 15px;
            background: #334155;
            border-radius: 10px;
            color: #fb923c;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.3s;
        }

        .nav-link {
            background: transparent;
            color: #94a3b8;
        }

        .nav-link:hover {
            background: #334155;
            color: white;
        }

        .nav-label {
            color: #64748b;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            margin-top: 20px;
            margin-bottom: 10px;
            padding-left: 5px;
        }

        /* Contenido Principal */
        .main-content { 
            flex: 1; 
            display: flex; 
            flex-direction: column; 
            overflow-y: auto; 
            padding-bottom: 40px; 
        }

        .topbar { 
            background: var(--white); 
            padding: 15px 35px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            border-bottom: 1px solid #e2e8f0; 
            position: sticky; 
            top: 0; 
            z-index: 50; 
        }

        .status-badge { 
            display: flex; 
            align-items: center; 
            gap: 8px; 
            font-size: 13px; 
            background: #f1f5f9; 
            padding: 6px 16px; 
            border-radius: 20px; 
            font-weight: 600;
        }

        .status-dot { width: 10px; height: 10px; background: #94a3b8; border-radius: 50%; }

        .dashboard-grid { padding: 30px; }

        /* Tarjetas de Resumen */
        .cards-container { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); 
            gap: 20px; 
            margin-bottom: 30px; 
        }

        .card { 
            background: var(--white); 
            padding: 24px; 
            border-radius: 16px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); 
        }

        .card-info p { margin: 0; color: #64748b; font-size: 12px; font-weight: 700; text-transform: uppercase; }
        .card-info h3 { margin: 8px 0 0; font-size: 32px; font-weight: 800; }

        .card-icon { 
            width: 55px; 
            height: 55px; 
            border-radius: 14px; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 24px; 
        }

        .icon-orange { background: #fff7ed; color: var(--primary); }
        .icon-blue { background: #eff6ff; color: var(--secondary); }

        /* Gráficas */
        .charts-container { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); 
            gap: 25px; 
        }

        .chart-box { 
            background: var(--white); 
            padding: 25px; 
            border-radius: 16px; 
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); 
        }

        .chart-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .chart-header h4 { margin: 0; font-size: 16px; color: #475569; }

        .canvas-wrapper { height: 320px; position: relative; }

        /* Responsividad */
        @media (max-width: 768px) {
            .sidebar { display: none; }
            .charts-container { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fa-solid fa-cloud-bolt"></i>
                <h2 style="margin:0; font-size: 22px; letter-spacing: 1px;">ARBELAEZ</h2>
            </div>
            
            <nav class="sidebar-nav">
                <div class="nav-item">
                    <i class="fa-solid fa-gauge-high"></i>
                    <span>Monitor v3.0</span>
                </div>

                <p class="nav-label">Reportes</p>
                
                <a href="export_csv.php?sensor=temperatura" class="nav-item nav-link">
                    <i class="fa-solid fa-file-csv"></i>
                    <span>Descargar Temp.</span>
                </a>
                
                <a href="export_csv.php?sensor=humedad" class="nav-item nav-link">
                    <i class="fa-solid fa-file-csv"></i>
                    <span>Descargar Hum.</span>
                </a>
            </nav>
        </aside>

        <!-- Contenido -->
        <main class="main-content">
            <header class="topbar">
                <h2 style="margin:0; font-size: 20px; color: #1e293b;">Estación Meteorológica</h2>
                <div class="status-badge">
                    <div class="status-dot" id="mqtt-dot"></div> 
                    <span id="mqtt-text">Conectando...</span>
                </div>
            </header>

            <div class="dashboard-grid">
                <!-- Tarjetas Superiores es para los contenedores -->
                <div class="cards-container">
                    <div class="card">
                        <div class="card-info">
                            <p>Temperatura</p>
                            <h3 id="temp-value">--°C</h3>
                        </div>
                        <div class="card-icon icon-orange">
                            <i class="fa-solid fa-temperature-full"></i>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-info">
                            <p>Humedad</p>
                            <h3 id="hum-value">--%</h3>
                        </div>
                        <div class="card-icon icon-blue">
                            <i class="fa-solid fa-droplet-degree"></i>
                        </div>
                    </div>
                </div>

                <!-- Bloque de Gráfica de temperatura -->
                <div class="charts-container">
                    <!-- Gráfica de Temperatura -->
                    <div class="chart-box">
                        <div class="chart-header">
                            <h4><i class="fa-solid fa-chart-line" style="color: var(--primary); margin-right: 8px;"></i> Historial Temperatura</h4>
                        </div>
                        <div class="canvas-wrapper">
                            <canvas id="tempChart"></canvas>
                        </div>
                    </div>

                    <!-- Gráfica de Humedad -->
                    <div class="chart-box">
                        <div class="chart-header">
                            <h4><i class="fa-solid fa-chart-area" style="color: var(--secondary); margin-right: 8px;"></i> Historial Humedad</h4>
                        </div>
                        <div class="canvas-wrapper">
                            <canvas id="humChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Vinculación del Script tomenlo como un llamado de la función-->
    <script src="script.js"></script>
</body>
</html>
